{
  "name": "tigertag-inventory",
  "version": "1.4.11",
  "description": "Tiger Studio Manager — desktop app",
  "main": "main.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild",
    "build:win": "electron-builder --win --publish always",
    "build:win:nopublish": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish always",
    "build:mac:local": "bash build/sign-and-notarize.sh",
    "build:mac:unsigned": "electron-builder --mac -c.mac.identity=null -c.mac.notarize=false",
    "build:linux": "electron-builder --linux --publish always",
    "build:all": "electron-builder -wml --publish always",
    "i18n:add": "node scripts/i18n-add.mjs",
    "i18n:check": "node scripts/check-i18n-consistency.mjs",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "electron-updater": "^6.1.7",
    "nfc-pcsc": "^0.8.1",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "io.tigertag.inventory",
    "productName": "Tiger Studio Manager",
    "copyright": "TigerTag",
    "publish": {
      "provider": "github",
      "owner": "TigerTag-Project",
      "repo": "TigerTag_Studio_Manager",
      "releaseType": "draft",
      "publisherName": null
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "services/**",
      "data/**",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/img/icon.ico",
      "artifactName": "Tiger-Studio-Manager-Setup-${version}.${ext}",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/img/icon.icns",
      "category": "public.app-category.utilities",
      "identity": "3D France (RT4W5WC9P2)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/img/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
