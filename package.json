{
  "name": "tigertag-inventory",
  "version": "1.3.0",
  "description": "TigerTag Studio Manager — desktop app",
  "main": "main.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -wml"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "nfc-pcsc": "^0.8.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "io.tigertag.inventory",
    "productName": "TigerTag Studio Manager",
    "copyright": "TigerTag",
    "publish": {
      "provider": "github",
      "owner": "TigerTag-Project",
      "repo": "TigerTag_Studio_Manager"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "services/**",
      "data/**",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/img/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/img/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/img/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
