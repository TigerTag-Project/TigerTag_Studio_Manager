# Apple notarization credentials (App Store Connect API Key)
# DO NOT COMMIT THIS FILE — copy to .env locally
#
# Get these from: https://appstoreconnect.apple.com/access/integrations/api
#
# 1. Create a new "Team Key" with role "Developer"
# 2. Download the .p8 file (only downloadable ONCE) and save it somewhere safe
# 3. Note the Key ID (10 chars) and Issuer ID (UUID)
#
# electron-builder will read these env vars automatically when building macOS targets.

# Path to the downloaded .p8 file (absolute path recommended)
APPLE_API_KEY=/Users/benglut/Documents/AppleKeys/AuthKey_XXXXXXXXXX.p8

# Key ID — 10 alphanumeric chars shown next to the key name in App Store Connect
APPLE_API_KEY_ID=XXXXXXXXXX

# Issuer ID — UUID shown at the top of the API Keys page
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000

# Team ID (already in package.json but useful for shell commands)
APPLE_TEAM_ID=RT4W5WC9P2
